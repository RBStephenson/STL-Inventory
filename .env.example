# Copy this to .env and adjust paths for your system
# Windows Docker Desktop — use forward slashes

# MyMiniFactory API key — get one free at https://www.myminifactory.com/settings/preferences
MMF_API_KEY=

STL_DRIVE_1=F:/3DModelLibrary
STL_DRIVE_2=E:/3D STLs

# Orynt3D thumbnail cache (Windows Store app)
# This path contains the GUID-named .jpg thumbnails Orynt3D generates
ORYNT3D_THUMBNAIL_CACHE=C:/Users/brent/AppData/Local/Packages/PlayablePrintsLimited.Orynt3D_vpht4nxhetrf0/LocalCache/Roaming/orynt3d/User Storage/Cache/orynt3dThumbnails
